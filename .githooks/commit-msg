#!/bin/sh
# Strip Cursor agent co-author trailer; sole author is the human developer.
# https://note.com/198619891990/n/na83710298c7e
msgfile="$1"
[ -z "$msgfile" ] || [ ! -f "$msgfile" ] && exit 0
tmp=$(mktemp)
while IFS= read -r line || [ -n "$line" ]; do
  case "$line" in
    Co-authored-by:*[Cc]ursor*) ;;
    Co-authored-by:*cursoragent@cursor.com*) ;;
    Made-with:*[Cc]ursor*) ;;
    Made-with:*Cursor*) ;;
    *cursoragent@cursor.com*) ;;
    *) printf '%s\n' "$line" ;;
  esac
done < "$msgfile" > "$tmp" && mv "$tmp" "$msgfile"
exit 0
