<Page
    x:Class="App1.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:App1.Views"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
    <views:PageScrollHost>
        <StackPanel Style="{StaticResource PageBaseStackPanelStyle}">
            <TextBlock x:Uid="Settings_SectionStartup" Style="{StaticResource SettingsSectionHeaderStyle}" />

            <Border Style="{StaticResource SettingsRowCardStyle}">
                <Grid Style="{StaticResource SettingsAlignedRowGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="{StaticResource SettingsActionColumnWidth}" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4" VerticalAlignment="Center" MinWidth="0">
                        <TextBlock x:Uid="Settings_AutoStart" FontWeight="SemiBold" />
                        <TextBlock x:Uid="Settings_AutoStartDesc" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid Grid.Column="1" Style="{StaticResource SettingsRowActionHostStyle}">
                        <ToggleSwitch x:Name="AutoStartToggle"
                                      Style="{StaticResource CompactSettingsToggleSwitchStyle}"
                                      Toggled="AutoStartToggle_Toggled" />
                    </Grid>
                </Grid>
            </Border>

            <TextBlock x:Uid="Settings_SectionUpdate" Style="{StaticResource SettingsSectionHeaderStyle}" />

            <Border Style="{StaticResource SettingsRowCardStyle}">
                <Grid Style="{StaticResource SettingsAlignedRowGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="{StaticResource SettingsActionColumnWidth}" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4" VerticalAlignment="Center" MinWidth="0">
                        <TextBlock x:Name="VersionText" FontWeight="SemiBold" />
                        <TextBlock x:Uid="Settings_UpdateDesc" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid Grid.Column="1" Style="{StaticResource SettingsRowActionHostStyle}">
                        <Button x:Name="CheckUpdateButton"
                                x:Uid="Settings_CheckUpdate"
                                Style="{StaticResource SettingsRowActionButtonStyle}"
                                Click="CheckUpdateButton_Click" />
                    </Grid>
                </Grid>
            </Border>

            <InfoBar x:Name="UpdateInfoBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Informational"
                     HorizontalAlignment="Stretch" />
        </StackPanel>
    </views:PageScrollHost>
</Page>
